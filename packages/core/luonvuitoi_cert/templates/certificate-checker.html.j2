{% extends "base.html.j2" %}

{% block title %}{{ t("verify.title", default="Certificate Verification") }} — {{ project.name }}{% endblock %}

{% block main %}
<section class="card">
  <h2>{{ t("verify.title", default="Certificate Verification") }}</h2>
  <p class="subtitle">{{ t("verify.subtitle", default="Scan the QR from a printed certificate to confirm authenticity.") }}</p>
  <form id="verify-form" autocomplete="off">
    <label for="blob">{{ t("verify.label_blob", default="QR payload") }}</label>
    <textarea id="blob" name="blob" rows="4" spellcheck="false" required></textarea>
    <div style="margin-top:14px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <button type="submit" id="submit-btn">{{ t("portal.verify_button", default="Verify") }}</button>
      <label class="upload-btn" id="upload-label" hidden style="background:var(--bg); color:var(--ink); border:1px solid var(--border); border-radius:8px; padding:10px 18px; cursor:pointer; font-size:0.95rem; font-weight:500; display:inline-flex; align-items:center; gap:6px; margin-bottom:0;">
        <span>🖼️</span>
        <span>{{ t("verify.upload_image", default="Upload QR image") }}</span>
        <input type="file" id="qr-file" accept="image/*" hidden>
      </label>
      <span id="status" class="badge" role="status" aria-live="polite" hidden></span>
      <span id="upload-hint" class="reason" role="status" aria-live="polite" hidden></span>
    </div>
  </form>
</section>

<section id="result" class="card" role="region" aria-live="polite" aria-atomic="true" hidden>
  <h2 id="result-title"></h2>
  <p id="result-reason" class="reason" hidden></p>
  <dl id="result-fields"></dl>
</section>
{% endblock %}

{% block scripts %}
<script src="{{ static_url_prefix }}/jsqr.min.js" defer{% if csp_nonce %} nonce="{{ csp_nonce }}"{% endif %}></script>
<script src="{{ static_url_prefix }}/qr-decode-helper.js" defer{% if csp_nonce %} nonce="{{ csp_nonce }}"{% endif %}></script>
<script{% if csp_nonce %} nonce="{{ csp_nonce }}"{% endif %}>
(function () {
  "use strict";
  const endpoint = {{ verify_endpoint | tojson }};
  const uploadLabels = {
    no_qr: {{ t("verify.upload_no_qr", default="No QR detected in image.") | tojson }},
    too_large: {{ t("verify.upload_too_large", default="Image too large (max 10 MB).") | tojson }},
    decode_unavailable: {{ t("verify.upload_unavailable", default="QR decoder unavailable.") | tojson }},
    read_failed: {{ t("verify.upload_read_failed", default="Could not read image file.") | tojson }},
  };
  const MAX_UPLOAD_BYTES = 10 * 1024 * 1024;
  const MAX_DECODE_DIMENSION = 1280;
  const labels = {
    valid: {{ t("verify.valid", default="Signature valid") | tojson }},
    tampered: {{ t("verify.tampered", default="Signature does not match — certificate may be altered.") | tojson }},
    fields: {
      sbd: {{ t("verify.field.sbd", default="Registration #") | tojson }},
      round_id: {{ t("verify.field.round_id", default="Round") | tojson }},
      subject_code: {{ t("verify.field.subject_code", default="Subject") | tojson }},
      result: {{ t("verify.field.result", default="Result") | tojson }},
      issued_at: {{ t("verify.field.issued_at", default="Issued") | tojson }},
    },
  };

  const form = document.getElementById("verify-form");
  const blobEl = document.getElementById("blob");
  const btn = document.getElementById("submit-btn");
  const badge = document.getElementById("status");
  const result = document.getElementById("result");
  const resultTitle = document.getElementById("result-title");
  const resultReason = document.getElementById("result-reason");
  const resultFields = document.getElementById("result-fields");

  function showBadge(ok, text) {
    badge.hidden = false;
    badge.classList.remove("ok", "bad");
    badge.classList.add(ok ? "ok" : "bad");
    badge.textContent = text;
  }

  function formatTs(seconds) {
    if (!seconds || typeof seconds !== "number" || !isFinite(seconds)) return "";
    try {
      const d = new Date(seconds * 1000);
      return d.toISOString().replace("T", " ").slice(0, 19) + " UTC";
    } catch (_) {
      return "";
    }
  }

  function render(response) {
    result.hidden = false;
    const valid = !!response.valid;
    resultTitle.textContent = valid ? labels.valid : labels.tampered;
    resultTitle.style.color = valid ? "var(--ok)" : "var(--bad)";
    resultReason.hidden = !response.reason;
    resultReason.textContent = response.reason || "";
    resultFields.innerHTML = "";
    const p = response.payload;
    if (p) {
      const pairs = [
        ["sbd", p.sbd],
        ["round_id", p.round_id],
        ["subject_code", p.subject_code],
        ["result", p.result],
        ["issued_at", formatTs(p.issued_at)],
      ];
      for (const [key, value] of pairs) {
        const dt = document.createElement("dt");
        dt.textContent = labels.fields[key] || key;
        const dd = document.createElement("dd");
        dd.textContent = value || "—";
        resultFields.appendChild(dt);
        resultFields.appendChild(dd);
      }
    }
  }

  async function submit(blob) {
    btn.disabled = true;
    showBadge(true, "…");
    try {
      const resp = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ blob }),
      });
      if (!resp.ok) {
        showBadge(false, "✗");
        render({ valid: false, reason: "server returned HTTP " + resp.status });
        return;
      }
      const data = await resp.json().catch(() => ({ valid: false, reason: "bad response" }));
      showBadge(!!data.valid, data.valid ? "✓" : "✗");
      render(data);
    } catch (err) {
      showBadge(false, "✗");
      render({ valid: false, reason: "network error: " + err.message });
    } finally {
      btn.disabled = false;
    }
  }

  form.addEventListener("submit", function (e) {
    e.preventDefault();
    const blob = (blobEl.value || "").trim();
    if (!blob) return;
    submit(blob);
  });

  // Auto-fill from ?blob= so scanned QRs can go straight to a verdict.
  const qs = new URLSearchParams(location.search);
  const incoming = qs.get("blob");
  if (incoming) {
    blobEl.value = incoming;
    submit(incoming);
  }

  // ── Image upload mode ────────────────────────────────────────────
  // Reveals the upload button only when both jsQR + helper have loaded.
  const fileInput = document.getElementById("qr-file");
  const uploadLabel = document.getElementById("upload-label");
  const uploadHint = document.getElementById("upload-hint");

  function showUploadHint(msg) {
    uploadHint.hidden = !msg;
    uploadHint.textContent = msg || "";
  }

  // Decode-bomb guard: a 9 MB JPEG can decompress to 25 000×25 000 px and OOM
  // the tab before any naturalWidth-based downscale runs. createImageBitmap
  // with resizeWidth/resizeHeight asks the browser to downscale during decode,
  // never materializing the full-resolution bitmap. Falls back to <img> + canvas
  // on browsers that don't support the resize options (very old Safari).
  function decodeFile(file) {
    if (typeof createImageBitmap === "function") {
      return createImageBitmap(file, {
        resizeWidth: MAX_DECODE_DIMENSION,
        resizeHeight: MAX_DECODE_DIMENSION,
        resizeQuality: "medium",
      })
        .then(function (bitmap) {
          try {
            return bitmapToImageData(bitmap);
          } finally {
            if (typeof bitmap.close === "function") bitmap.close();
          }
        });
    }
    return loadImageFallback(file).then(imageToImageData);
  }

  function bitmapToImageData(bitmap) {
    const canvas = document.createElement("canvas");
    canvas.width = bitmap.width;
    canvas.height = bitmap.height;
    const ctx = canvas.getContext("2d", { willReadFrequently: true });
    if (!ctx) return null;
    ctx.drawImage(bitmap, 0, 0);
    return ctx.getImageData(0, 0, bitmap.width, bitmap.height);
  }

  function loadImageFallback(file) {
    return new Promise(function (resolve, reject) {
      const url = URL.createObjectURL(file);
      const img = new Image();
      img.onload = function () { URL.revokeObjectURL(url); resolve(img); };
      img.onerror = function () { URL.revokeObjectURL(url); reject(new Error("image load failed")); };
      img.src = url;
    });
  }

  function imageToImageData(img) {
    let w = img.naturalWidth;
    let h = img.naturalHeight;
    if (!w || !h) return null;
    if (w > MAX_DECODE_DIMENSION || h > MAX_DECODE_DIMENSION) {
      const scale = MAX_DECODE_DIMENSION / Math.max(w, h);
      w = Math.round(w * scale);
      h = Math.round(h * scale);
    }
    const canvas = document.createElement("canvas");
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext("2d", { willReadFrequently: true });
    if (!ctx) return null;
    ctx.drawImage(img, 0, 0, w, h);
    return ctx.getImageData(0, 0, w, h);
  }

  function handleUpload(file) {
    if (!file) return;
    if (file.size > MAX_UPLOAD_BYTES) {
      showUploadHint(uploadLabels.too_large);
      return;
    }
    if (!window.LvtQR || typeof window.LvtQR.decode !== "function") {
      showUploadHint(uploadLabels.decode_unavailable);
      return;
    }
    showUploadHint("");
    decodeFile(file)
      .then(function (imageData) {
        if (!imageData) { showUploadHint(uploadLabels.read_failed); return; }
        const decoded = window.LvtQR.decode(imageData);
        if (decoded) {
          blobEl.value = decoded;
          submit(decoded);
        } else {
          showUploadHint(uploadLabels.no_qr);
        }
      })
      .catch(function () { showUploadHint(uploadLabels.read_failed); });
  }

  if (fileInput) {
    fileInput.addEventListener("change", function (e) {
      const file = e.target.files && e.target.files[0];
      handleUpload(file);
      // Reset so picking the same file twice re-fires `change`.
      e.target.value = "";
    });
    // Reveal the button only when the decoder is wired up. The two vendored
    // <script defer> tags above this inline block run in document order before
    // DOMContentLoaded fires, so listening for that event observes both
    // window.jsQR and window.LvtQR reliably across browsers (incl. Safari <16
    // which had setTimeout-based observation flakiness).
    function revealUploadIfReady() {
      if (window.LvtQR && typeof window.LvtQR.decode === "function" && typeof window.jsQR === "function") {
        uploadLabel.hidden = false;
      }
    }
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", revealUploadIfReady, { once: true });
    } else {
      revealUploadIfReady();
    }
  }
})();
</script>
{% endblock %}
