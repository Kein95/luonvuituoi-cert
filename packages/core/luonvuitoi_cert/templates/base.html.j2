<!doctype html>
<html lang="{{ project.locale }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}{{ project.name }}{% endblock %}</title>
  <style>
    :root {
      --primary: {{ branding.primary_color }};
      --accent: {{ branding.accent_color }};
      --ink: #111827;
      --muted: #6b7280;
      --surface: #ffffff;
      --bg: #f4f6fb;
      --ok: #059669;
      --bad: #dc2626;
      --border: #e5e7eb;
      --radius: 12px;
      --shadow: 0 6px 20px rgba(17, 24, 39, 0.06);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font: 15px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      color: var(--ink);
      background: var(--bg);
    }
    header.brand {
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: #fff;
      padding: 20px 24px;
    }
    header.brand .inner {
      max-width: 920px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    header.brand img { height: 32px; width: auto; }
    header.brand h1 {
      margin: 0;
      font-size: 1.1rem;
      font-weight: 600;
      letter-spacing: 0.2px;
    }
    main {
      max-width: 720px;
      margin: 32px auto;
      padding: 0 20px;
    }
    .card {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 28px;
    }
    .card + .card { margin-top: 20px; }
    h2 { margin: 0 0 16px; font-size: 1.4rem; }
    p.subtitle { color: var(--muted); margin: -8px 0 20px; }
    label { display: block; font-weight: 500; margin-bottom: 6px; font-size: 0.92rem; }
    textarea, input {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 0.88rem;
      resize: vertical;
    }
    textarea:focus, input:focus {
      outline: 2px solid var(--primary);
      outline-offset: -1px;
    }
    button {
      background: var(--primary);
      color: #fff;
      border: 0;
      border-radius: 8px;
      padding: 10px 18px;
      font-size: 0.95rem;
      font-weight: 500;
      cursor: pointer;
      transition: filter 120ms;
    }
    button:hover { filter: brightness(0.95); }
    button:disabled { opacity: 0.5; cursor: not-allowed; }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.88rem;
    }
    .badge.ok { background: #d1fae5; color: var(--ok); }
    .badge.bad { background: #fee2e2; color: var(--bad); }
    dl { margin: 16px 0 0; display: grid; grid-template-columns: auto 1fr; gap: 8px 20px; }
    dt { color: var(--muted); font-size: 0.88rem; }
    dd { margin: 0; }
    .reason { color: var(--bad); margin-top: 10px; font-size: 0.92rem; }
    footer { text-align: center; color: var(--muted); font-size: 0.8rem; padding: 20px; }
  </style>
</head>
<body>
  <header class="brand">
    <div class="inner">
      {% if branding.logo_url %}<img src="{{ branding.logo_url }}" alt="">{% endif %}
      <h1>{{ project.name }}</h1>
    </div>
  </header>
  <main>
    {% block main %}{% endblock %}
  </main>
  <footer>{{ t("portal.title", default=project.name) }}</footer>
  {% block scripts %}{% endblock %}
</body>
</html>
