# Copy to .env and fill in values. Never commit .env.

# Public base URL used when building magic-link emails + QR verify URLs.
# Pin to your real deploy origin so the Host header can't be spoofed.
# Leave unset only for localhost dev (falls back to the request Host).
PUBLIC_BASE_URL=https://your-domain.example

# Comma-separated list of origins allowed to call /api/*. Use "*" only when
# the portal is public and serves no authenticated cookies. Unset defaults to
# "*" — set this explicitly for any real deploy.
ALLOWED_ORIGINS=https://your-domain.example

# REQUIRED: JWT signing secret for admin tokens. The app refuses to boot while
# this is the placeholder. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string-32-chars-min

# REQUIRED: initial super-admin password. The app refuses to boot while this is
# the placeholder. Change it and rotate after first login.
ADMIN_DEFAULT_PASSWORD=change-me

# Key-value backend for rate limits + single-use tokens: local | upstash | vercel-kv
# 'local' is single-process only — use upstash/vercel-kv for >1 worker.
KV_BACKEND=local

# Upstash Redis (only needed if KV_BACKEND=upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel KV (only needed if KV_BACKEND=vercel-kv)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend (only needed when admin auth_mode = otp_email / magic_link)
RESEND_API_KEY=
CERT_EMAIL_FROM=onboarding@resend.dev

# Google Sheets webhook URL for optional activity-log forwarding
GSHEET_WEBHOOK_URL=

# Trust the X-Forwarded-For header for client IP (rate-limit bucketing).
# Set to 1 ONLY when deploying behind a reverse proxy that overwrites it
# (Nginx, Caddy, Vercel, Cloud Run). Otherwise clients can spoof their IP.
TRUST_PROXY_HEADERS=0

# Emit Strict-Transport-Security on every response. Enable only when the site
# is served exclusively over HTTPS — HSTS is cached by browsers.
FORCE_HSTS=0
