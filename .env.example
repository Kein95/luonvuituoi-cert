# Copy to .env and fill in values. Never commit .env.

# Public base URL used when building magic-link emails + QR verify URLs.
# Pin to your real deploy origin so the Host header can't be spoofed.
PUBLIC_BASE_URL=https://your-domain.example

# Comma-separated list of origins allowed to call /api/*. Use "*" only when
# the portal is public and does not serve authenticated cookies.
ALLOWED_ORIGINS=https://your-domain.example

# JWT signing secret for admin tokens (rotate on compromise).
JWT_SECRET=change-me-to-a-long-random-string

# Initial admin password for the first super-admin account.
ADMIN_DEFAULT_PASSWORD=change-me

# Key-value backend for rate limits + admin overrides: local | upstash | vercel-kv
KV_BACKEND=local

# Upstash Redis (only needed if KV_BACKEND=upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel KV (only needed if KV_BACKEND=vercel-kv)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend API key (only needed when admin auth_mode = otp_email / magic_link)
RESEND_API_KEY=
CERT_EMAIL_FROM=onboarding@resend.dev

# Google Sheets webhook URL for optional activity log forwarding
GSHEET_WEBHOOK_URL=

# Path to RSA private key for QR signing (generated by `lvt-cert gen-keys`)
QR_PRIVATE_KEY_PATH=./private_key.pem

# Trust the X-Forwarded-For header for client IP (rate-limit bucketing).
# Set to 1 ONLY when deploying behind a reverse proxy that overwrites it
# (Nginx, Caddy, Vercel, Cloud Run). Otherwise clients can spoof their IP.
TRUST_PROXY_HEADERS=0

# Emit Strict-Transport-Security header on every response. Enable only when
# the site is served exclusively over HTTPS — HSTS is cached by browsers.
FORCE_HSTS=0
